<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ item.title }} | Jerusalem Signet</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../../css/style.css">
    <style>
        /* Pinterest landing: mirrors test.html layout; scoped tweaks only */
        .pinterest-landing-wrap {
            max-width: 520px;
            margin: 0 auto;
            padding: 24px 20px 48px;
            text-align: center;
        }
        .pinterest-landing-wrap .wisdom-post {
            text-align: left;
        }
        .pinterest-landing-wrap .wisdom-post h2 {
            text-align: center;
        }
        .pinterest-landing-icon {
            width: 100px;
            height: auto;
            margin: 0 auto 20px;
            filter: grayscale(1);
        }
        .pinterest-landing-verse-en {
            font-style: italic;
            color: #666;
            margin-bottom: 24px;
            text-align: center;
            font-size: 1rem;
            line-height: 1.6;
        }
        .pinterest-landing-actions {
            text-align: center;
            margin-top: 32px;
        }
    </style>
</head>
<body class="subpage wisdom-page">
    <main class="posts-container" style="background: var(--white); padding: 48px 5% 80px;">
        <div class="pinterest-landing-wrap">
            <article class="wisdom-post pinterest-landing">
                <img src="{{ item.icon }}" alt="" class="pinterest-landing-icon" width="100" height="100">
                <h2>{{ item.title }}</h2>

                {% if item.verse_he %}
                <div class="verse-he">{{ item.verse_he }}</div>
                {% endif %}
                {% if item.verse_en %}
                <p class="pinterest-landing-verse-en">{{ item.verse_en }}</p>
                {% endif %}

                <div class="post-content">
                    {% for p in item.content %}
                    <p>{{ p }}</p>
                    {% endfor %}
                </div>

                <div class="pinterest-landing-actions">
                    <a href="../../wisdom.html" class="cta-button">Back to Wisdom</a>
                </div>
            </article>
        </div>
    </main>
</body>
</html>
